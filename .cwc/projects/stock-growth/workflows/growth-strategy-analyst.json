        912,
        480
      ],
      "parameters": {
        "method": "GET",
        "url": "https://financialmodelingprep.com/api/v3/{endpoint}",
        "description": "FMP API: profile/{ticker}, ratios/{ticker}, income-statement/{ticker}, key-metrics/{ticker}. Append ?apikey=."
      }
    },
    {
      "id": "codeTool1",
      "name": "Growth Calc",
      "type": "codeTool",
      "typeVersion": 1,
      "position": [
        1024,
        480
      ],
      "parameters": {
        "language": "js",
        "code": "try{const d=JSON.parse(input);const r=d.revenues||[];const cagr=(a)=>{if(a.length<2)return 0;return(Math.pow(a[0]/a[a.length-1],1/(a.length-1))-1)*100;};return JSON.stringify({revenue_cagr:cagr(r).toFixed(2)+'%',latest_growth:r.length>=2?((r[0]-r[1])/Math.abs(r[1])*100).toFixed(2)+'%':'N/A'});}catch(e){return'Error: '+e.message;}"
      }
    },
    {
