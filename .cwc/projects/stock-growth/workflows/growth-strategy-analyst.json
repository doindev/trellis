{
  "configId": "growth-strategy-analyst",
  "name": "Growth Strategy Analyst",
  "description": "AI agent for growth investing. Evaluates companies for above-average earnings growth, revenue acceleration, expanding margins. Sub-agents: Fundamental Screener, Momentum Analyst.",
  "type": "AGENT",
  "nodes": [
    {
      "id": "agent1",
      "name": "Growth Strategy Analyst",
      "type": "aiAgent",
      "typeVersion": 1,
      "position": [
        704,
        304
      ],
      "parameters": {
        "systemMessage": "You are a Growth Strategy Analyst specializing in high-growth companies.\n\nPhilosophy:\n- Revenue growth >15% YoY, expanding margins, strong forward guidance\n- Evaluate TAM, competitive moats, accept higher P/E if justified by trajectory\n- Target: Tech, Biotech, Clean Energy, AI/ML, SaaS\n\nAnalysis steps:\n1. Revenue growth trends (3-5yr CAGR)\n2. Earnings acceleration/deceleration\n3. Management execution vs guidance\n4. Competitive positioning, market share gains\n5. Score 1-10 with justification\n\nOutput JSON: ticker, growth_score, revenue_growth_rate, earnings_trajectory, competitive_moat_rating, risk_factors, recommendation (STRONG_BUY/BUY/HOLD/AVOID), thesis.",
        "prompt": "{{$json.context}}",
        "maxIterations": 15
      }
    },
    {
      "id": "model1",
      "name": "Claude Sonnet",
      "type": "anthropicChatModel",
      "typeVersion": 1,
      "position": [
        304,
        480
      ],
      "parameters": {
        "model": "claude-sonnet-4-20250514",
        "temperature": 0.3,
        "maxTokens": 4096
      }
    },
    {
      "id": "memory1",
      "name": "Memory",
      "type": "memoryPostgresChat",
      "typeVersion": 1,
      "position": [
        416,
        480
      ],
      "parameters": {
        "sessionId": "growth_analyst_{{$json.ticker}}"
      }
    },
    {
      "id": "think1",
      "name": "Think",
      "type": "toolThink",
      "typeVersion": 1,
      "position": [
        800,
        480
      ],
      "parameters": {}
