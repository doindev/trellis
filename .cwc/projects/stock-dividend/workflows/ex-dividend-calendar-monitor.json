{
  "configId": "ex-dividend-calendar-monitor",
  "name": "Ex-Dividend Calendar Monitor",
  "description": "Daily (6:30 AM ET, Mon-Fri): Checks watchlist stocks with ex-dividend dates within 7 days. Creates alerts for capture opportunities.",
  "type": "WORKFLOW",
  "nodes": [
    {
      "id": "trigger1",
      "name": "Weekday 6:30AM",
      "type": "scheduleTrigger",
      "typeVersion": 1,
      "position": [
        200,
        300
      ],
      "parameters": {
        "rule": "cronExpression",
        "cronExpression": "30 6 * * 1-5",
        "timezone": "America/New_York"
      }
    },
    {
      "id": "q1",
      "name": "Check Ex-Dates",
      "type": "postgres",
      "typeVersion": 1,
      "position": [
        450,
        300
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT dh.ticker,dh.ex_date,dh.amount,dh.payment_date,t.company_name FROM dividend_history dh JOIN tickers t ON dh.ticker=t.ticker JOIN watchlists w ON dh.ticker=w.ticker AND w.strategy='dividend' WHERE dh.ex_date BETWEEN CURRENT_DATE AND CURRENT_DATE+INTERVAL '7 days' ORDER BY dh.ex_date"
      }
    },
    {
      "id": "if1",
      "name": "Any?",
      "type": "if",
      "typeVersion": 1,
      "position": [
        700,
        300
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "1",
              "operator": {
                "type": "string",
                "operation": "isNotEmpty"
              },
              "leftValue": "={{$json.ticker}}"
            }
          ]
        }
      }
    },
    {
      "id": "al",
      "name": "Alert",
      "type": "postgres",
      "typeVersion": 1,
      "position": [
        950,
        200
      ],
      "parameters": {
        "operation": "executeSql",
        "query": "INSERT INTO alerts (ticker,alert_type,strategy,message,severity,metadata) VALUES ('{{$json.ticker}}','ex_dividend_upcoming','dividend','Ex-dividend for {{$json.company_name}} ({{$json.ticker}}) on {{$json.ex_date}}. Amount: ${{$json.amount}}','info','{\"ex_date\":\"{{$json.ex_date}}\",\"amount\":{{$json.amount}}}');"
      }
    }
  ],
  "connections": {
    "trigger1": {
      "main": [
        [
          {
            "node": "q1",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "q1": {
      "main": [
        [
          {
            "node": "if1",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "if1": {
      "main": [
        [
          {
            "node": "al",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
