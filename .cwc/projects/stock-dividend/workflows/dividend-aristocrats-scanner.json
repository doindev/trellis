{
  "configId" : "dividend-aristocrats-scanner",
  "name" : "Dividend Aristocrats Scanner",
  "description" : "Daily (7:30 AM ET, Mon-Fri): Screens dividend stocks with yield>2%, payout<75%, FCF>0, D/E<2, cap>$2B.",
  "type" : "WORKFLOW",
  "published" : true,
  "nodes" : [ {
    "id" : "trigger1",
    "name" : "Weekday 7:30AM",
    "type" : "scheduleTrigger",
    "typeVersion" : 1,
    "position" : [ 200, 300 ],
    "parameters" : {
      "rule" : "cronExpression",
      "cronExpression" : "30 7 * * 1-5",
      "timezone" : "America/New_York"
    }
  }, {
    "id" : "note1",
    "name" : "Setup",
    "type" : "stickyNote",
    "typeVersion" : 1,
    "position" : [ 180, 80 ],
    "parameters" : {
      "content" : "## Dividend Scanner\n\nRequired: postgresApi, neo4j\nCriteria: yield>2%, payout<75%, FCF>0, D/E<2, cap>$2B"
    }
  }, {
    "id" : "sc",
    "name" : "Screen",
    "type" : "postgres",
    "typeVersion" : 1,
    "position" : [ 450, 300 ],
    "parameters" : {
      "operation" : "executeQuery",
      "query" : "SELECT t.ticker,t.company_name,t.sector,t.market_cap,f.dividend_yield,f.payout_ratio,f.free_cash_flow,f.debt_to_equity,f.current_ratio,f.roe,f.net_margin,f.pe_ratio,(SELECT COUNT(DISTINCT ex_date) FROM dividend_history dh WHERE dh.ticker=t.ticker) as div_payments FROM tickers t JOIN fundamentals f ON t.ticker=f.ticker WHERE t.is_active=true AND f.dividend_yield>0.02 AND f.payout_ratio>0 AND f.payout_ratio<0.75 AND f.free_cash_flow>0 AND f.debt_to_equity<2.0 AND t.market_cap>2000000000 AND f.period_date=(SELECT MAX(period_date) FROM fundamentals WHERE ticker=t.ticker) ORDER BY f.dividend_yield DESC LIMIT 50"
    },
    "credentials" : {
      "postgresApi" : {
        "ref" : "postgresql-account"
      }
    }
  }, {
    "id" : "ds",
    "name" : "Score",
    "type" : "code",
    "typeVersion" : 1,
    "position" : [ 700, 300 ],
    "parameters" : {
      "language" : "javaScript",
      "mode" : "runOnceForEachItem",
      "jsCode" : "const d=$json;let s=0;s+=d.dividend_yield>0.04?3:d.dividend_yield>0.03?2:1;s+=d.payout_ratio<0.5?3:d.payout_ratio<0.65?2:1;s+=d.free_cash_flow>1e9?2:1;s+=d.debt_to_equity<1?2:1;s+=d.div_payments>20?3:d.div_payments>10?2:1;return [{json:{...d,dividend_score:s}}];"
    }
  }, {
    "id" : "pw",
    "name" : "Watchlist",
    "type" : "postgres",
    "typeVersion" : 1,
    "position" : [ 950, 200 ],
    "parameters" : {
      "operation" : "executeSql",
      "query" : "INSERT INTO watchlists (strategy,ticker,score,status,metadata) VALUES ('dividend',?,?,'active',?) ON CONFLICT (strategy,ticker) DO UPDATE SET score=EXCLUDED.score,metadata=EXCLUDED.metadata,status='active';",
      "queryParameters" : [ {
        "value" : "={{$json.ticker}}",
        "type" : "string"
      }, {
        "value" : "={{$json.dividend_score}}",
        "type" : "number"
      }, {
        "value" : "={{'{\"yield\":' + $json.dividend_yield + ',\"payout\":' + $json.payout_ratio + '}'}}",
        "type" : "string"
      } ]
    },
    "credentials" : {
      "postgresApi" : {
        "ref" : "postgresql-account"
      }
    }
  }, {
    "id" : "n4",
    "name" : "Neo4j Watchlist",
    "type" : "neo4j",
    "typeVersion" : 1,
    "position" : [ 950, 450 ],
    "parameters" : {
      "operation" : "executeStatement",
      "query" : "MATCH (c:Company {ticker:$ticker}),(w:Watchlist {name:'dividend'}) MERGE (c)-[r:IN_WATCHLIST]->(w) SET r.score=$score,r.updatedAt=datetime();",
      "parameters" : "{\"ticker\":\"{{$json.ticker}}\",\"score\":{{$json.dividend_score}}}"
    },
    "credentials" : {
      "neo4j" : {
        "ref" : "neo4j-account"
      }
    }
  } ],
  "connections" : {
    "trigger1" : {
      "main" : [ [ {
        "node" : "sc",
        "type" : "main",
        "index" : 0
      } ] ]
    },
    "sc" : {
      "main" : [ [ {
        "node" : "ds",
        "type" : "main",
        "index" : 0
      } ] ]
    },
    "ds" : {
      "main" : [ [ {
        "node" : "pw",
        "type" : "main",
        "index" : 0
      }, {
        "node" : "n4",
        "type" : "main",
        "index" : 0
      } ] ]
    }
  }
}