{
  "configId" : "stock-dividend",
  "name" : "Stock Research - Income & Dividend Investing",
  "type" : "TEAM",
  "contextPath" : "stock-dividend",
  "description" : "Income/dividend strategy: generates regular cash flow from dividend-paying stocks. Tracks Dividend Aristocrats, payout ratios, dividend safety scores, yield analysis, and ex-dividend calendars.",
  "credentials" : [ {
    "ref" : "neo4j-account",
    "name" : "Neo4j account",
    "type" : "neo4j",
    "data" : {
      "uri" : "{{env:STOCK_DIVIDEND_NEO4J_ACCOUNT_URI}}",
      "username" : "{{env:STOCK_DIVIDEND_NEO4J_ACCOUNT_USERNAME}}",
      "database" : "{{env:STOCK_DIVIDEND_NEO4J_ACCOUNT_DATABASE}}",
      "password" : "{{env:STOCK_DIVIDEND_NEO4J_ACCOUNT_PASSWORD}}"
    }
  }, {
    "ref" : "postgresql-account",
    "name" : "PostgreSQL account",
    "type" : "postgresApi",
    "data" : {
      "host" : "{{env:postgresql.host}}",
      "port" : "{{env:postgresql.port}}",
      "ssl" : "{{env:postgresql.ssl}}",
      "database" : "{{env:postgresql.database}}",
      "username" : "{{env:postgresql.username}}",
      "password" : "{{env:postgresql.password}}"
    }
  } ]
}