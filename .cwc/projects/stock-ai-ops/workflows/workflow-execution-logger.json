{
  "configId" : "workflow-execution-logger",
  "name" : "Workflow Execution Logger",
  "description" : "Error trigger: Automatically logs workflow failures to workflow_execution_log. Captures workflow ID, name, errors, timing. Critical for AI Ops health monitoring.",
  "type" : "WORKFLOW",
  "published" : true,
  "nodes" : [ {
    "id" : "trigger1",
    "name" : "On Error",
    "type" : "errorTrigger",
    "typeVersion" : 1,
    "position" : [ 200, 300 ],
    "parameters" : { }
  }, {
    "id" : "note1",
    "name" : "Setup",
    "type" : "stickyNote",
    "typeVersion" : 1,
    "position" : [ 180, 80 ],
    "parameters" : {
      "content" : "## Execution Logger\n\nRequired: postgresApi\nEvent-driven, no schedule needed"
    }
  }, {
    "id" : "ex",
    "name" : "Extract",
    "type" : "code",
    "typeVersion" : 1,
    "position" : [ 450, 300 ],
    "parameters" : {
      "language" : "javaScript",
      "mode" : "runOnceForAllItems",
      "jsCode" : "const d=$input.first().json;const exec=d.execution||{};const wf=d.workflow||{};return [{json:{workflow_id:wf.id||'unknown',workflow_name:wf.name||'unknown',execution_id:exec.id||'',status:'error',started_at:exec.startedAt||new Date().toISOString(),completed_at:new Date().toISOString(),duration_ms:exec.duration||0,error_message:(d.error?.message||d.errorMessage||'Unknown').substring(0,500).replace(/'/g,'')}}];"
    }
  }, {
    "id" : "pg",
    "name" : "Log",
    "type" : "postgres",
    "typeVersion" : 1,
    "position" : [ 750, 300 ],
    "parameters" : {
      "operation" : "executeSql",
      "query" : "INSERT INTO workflow_execution_log (workflow_id,workflow_name,execution_id,status,started_at,completed_at,duration_ms,error_message) VALUES (?,?,?,?,?,?,?,?);",
      "queryParameters" : [ {
        "value" : "={{$json.workflow_id}}",
        "type" : "string"
      }, {
        "value" : "={{$json.workflow_name}}",
        "type" : "string"
      }, {
        "value" : "={{$json.execution_id}}",
        "type" : "string"
      }, {
        "value" : "={{$json.status}}",
        "type" : "string"
      }, {
        "value" : "={{$json.started_at}}",
        "type" : "string"
      }, {
        "value" : "={{$json.completed_at}}",
        "type" : "string"
      }, {
        "value" : "={{$json.duration_ms}}",
        "type" : "number"
      }, {
        "value" : "={{$json.error_message}}",
        "type" : "string"
      } ]
    },
    "credentials" : {
      "postgresApi" : {
        "ref" : "postgresql-account"
      }
    }
  } ],
  "connections" : {
    "trigger1" : {
      "main" : [ [ {
        "node" : "ex",
        "type" : "main",
        "index" : 0
      } ] ]
    },
    "ex" : {
      "main" : [ [ {
        "node" : "pg",
        "type" : "main",
        "index" : 0
      } ] ]
    }
  }
}