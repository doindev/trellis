{
  "configId": "ai-operations-orchestrator",
  "name": "AI Operations Orchestrator",
  "description": "Master AI agent overseeing the entire platform. Monitors workflow health, evaluates strategy performance, discovers optimizations, researches/implements new strategies. 4 sub-agents: Health Monitor, Performance Evaluator, Strategy Researcher, Workflow Implementer (with CWC Platform Tool).",
  "type": "AGENT",
