      "parameters": {
        "language": "js",
        "code": "try{const d=JSON.parse(input);const l=d.logs||[];return JSON.stringify({total:l.length,success:l.filter(x=>x.status==='success').length,failed:l.filter(x=>x.status!=='success').length,failure_rate:l.length?(l.filter(x=>x.status!=='success').length/l.length*100).toFixed(1)+'%':'0%',errors:l.filter(x=>x.error_message).map(x=>({workflow:x.workflow_name,error:x.error_message}))});}catch(e){return'Error: '+e.message;}"
      }
