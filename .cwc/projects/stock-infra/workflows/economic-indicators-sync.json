{
  "configId" : "economic-indicators-sync",
  "name" : "Economic Indicators Sync",
  "description" : "Weekly (Sunday 8 AM ET): Fetches GDP, CPI, unemployment, fed funds rate, 10Y treasury, VIX, consumer sentiment, yield spread, and jobless claims from FRED API.",
  "type" : "WORKFLOW",
  "published" : true,
  "nodes" : [ {
    "id" : "trigger1",
    "name" : "Sunday 8AM ET",
    "type" : "scheduleTrigger",
    "typeVersion" : 1,
    "position" : [ 512, 160 ],
    "parameters" : {
      "rule" : "cronExpression",
      "cronExpression" : "0 8 * * 0",
      "timezone" : "America/New_York"
    }
  }, {
    "id" : "note1",
    "name" : "Setup",
    "type" : "stickyNote",
    "typeVersion" : 1,
    "position" : [ 176, 80 ],
    "parameters" : {
      "content" : "## Economic Indicators\n\nRequired: httpHeaderAuth (FRED API Key), postgresApi\nSeries: GDP, CPIAUCSL, UNRATE, DFF, DGS10, UMCSENT, VIXCLS, T10Y2Y, ICSA"
    }
  }, {
    "id" : "defs",
    "name" : "Define Series",
    "type" : "code",
    "typeVersion" : 1,
    "position" : [ 704, 160 ],
    "parameters" : {
      "language" : "javaScript",
      "mode" : "runOnceForAllItems",
      "jsCode" : "return ['GDP','CPIAUCSL','UNRATE','DFF','DGS10','UMCSENT','VIXCLS','T10Y2Y','ICSA'].map(s=>({json:{series_id:s}}));"
    }
  }, {
    "id" : "loop1",
    "name" : "Each",
    "type" : "loopOverItems",
    "typeVersion" : 1,
    "position" : [ 896, 160 ],
    "parameters" : {
      "batchSize" : 1
    }
  }, {
    "id" : "fetch1",
    "name" : "FRED API",
    "type" : "httpRequest",
    "typeVersion" : 1,
    "position" : [ 1088, 96 ],
    "parameters" : {
      "method" : "GET",
      "url" : "=https://api.stlouisfed.org/fred/series/observations?series_id={{$json.series_id}}&api_key={{$credentials.fred_api_key.value}}&file_type=json&sort_order=desc&limit=10",
      "authentication" : "none"
    }
  }, {
    "id" : "tx",
    "name" : "Transform",
    "type" : "code",
    "typeVersion" : 1,
    "position" : [ 1488, 160 ],
    "parameters" : {
      "language" : "javaScript",
      "mode" : "runOnceForAllItems",
      "jsCode" : "const items = $input.all();\n// Merge node combines: input 0 = FRED response, input 1 = Loop item with series_id\nconst fredData = items[0]?.json || {};\nconst loopItem = items[1]?.json || {};\nconst seriesId = loopItem.series_id || fredData.series_id || '';\nconst obs = fredData.observations || [];\n\nreturn obs.filter(o => o.value !== '.').map(o => ({\n  json: {\n    indicator_id: seriesId,\n    observation_date: o.date,\n    value: parseFloat(o.value)\n  }\n}));"
    }
  }, {
    "id" : "pg1",
    "name" : "Store",
    "type" : "postgres",
    "typeVersion" : 1,
    "position" : [ 1680, 160 ],
    "parameters" : {
      "operation" : "executeSql",
      "query" : "INSERT INTO economic_indicators (indicator_id,indicator_name,observation_date,value,unit) VALUES ('{{$json.indicator_id}}','','{{$json.observation_date}}',{{$json.value}},'') ON CONFLICT (indicator_id,observation_date) DO UPDATE SET value=EXCLUDED.value;"
    },
    "credentials" : {
      "postgresApi" : {
        "ref" : "postgresql-account"
      }
    }
  }, {
    "id" : "node_1774737593137_0",
    "name" : "Merge",
    "type" : "merge",
    "typeVersion" : 1,
    "parameters" : { },
    "position" : [ 1296, 160 ]
  } ],
  "connections" : {
    "trigger1" : {
      "main" : [ [ {
        "node" : "defs",
        "type" : "main",
        "index" : 0
      } ] ]
    },
    "defs" : {
      "main" : [ [ {
        "node" : "loop1",
        "type" : "main",
        "index" : 0
      } ] ]
    },
    "loop1" : {
      "main" : [ [ ], [ {
        "node" : "fetch1",
        "type" : "main",
        "index" : 0
      }, {
        "node" : "node_1774737593137_0",
        "type" : "main",
        "index" : 1
      } ] ]
    },
    "fetch1" : {
      "main" : [ [ {
        "node" : "node_1774737593137_0",
        "type" : "main",
        "index" : 0
      } ] ]
    },
    "tx" : {
      "main" : [ [ {
        "node" : "pg1",
        "type" : "main",
        "index" : 0
      } ] ]
    },
    "node_1774737593137_0" : {
      "main" : [ [ {
        "node" : "tx",
        "type" : "main",
        "index" : 0
      } ] ]
    }
  }
}