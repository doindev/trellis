{
  "configId": "stock-infra",
  "name": "Stock Research - Market Infrastructure",
  "type": "TEAM",
  "contextPath": "stock-infra",
  "description": "Shared data pipelines: ticker universe management, OHLCV price ingestion, company fundamentals sync, economic indicators, and database schema initialization. Backs all strategy projects via PostgreSQL and Neo4j.",
  "credentials": [
    {
      "ref": "fmp-api-key",
      "name": "FMP API Key",
      "type": "httpQueryAuth",
      "data": {
        "name": "fmp_api_key",
        "value": "{{env:fmp.api.key}}"
      }
    },
    {
      "ref": "polygon-api-key",
      "name": "Polygon.io API Key",
      "type": "httpHeaderAuth",
      "data": {
        "name": "apikey",
        "value": "{{env:polygon.api.key}}"
      }
    },
    {
      "ref": "finnhub-api-key",
      "name": "Finnhub API Key",
      "type": "httpHeaderAuth",
      "data": {
        "name": "token",
        "value": "{{env:finnhub.api.key}}"
      }
    },
    {
      "ref": "fred-api-key",
      "name": "FRED API Key",
      "type": "httpHeaderAuth",
      "data": {
        "name": "api_key",
        "value": "{{env:fred.api.key}}"
      }
    }
  ]
}
