{
  "name": "Postgres Test - Create Table & Insert",
  "description": "Checks if wf_logs table exists, creates it if not, inserts a random record, then returns the latest row.",
  "published": false,
  "currentVersion": 0,
  "nodes": [
    {
      "id": "trigger1",
      "name": "Manual Trigger",
      "type": "manualTrigger",
      "typeVersion": 1,
      "position": [100, 300],
      "parameters": {}
    },
    {
      "id": "checkTable1",
      "name": "Check Table Exists",
      "type": "postgres",
      "typeVersion": 1,
      "position": [350, 300],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT EXISTS (SELECT FROM information_schema.tables WHERE table_name = 'wf_logs') AS table_exists"
      },
      "credentials": { "postgresApi": { "id": "REPLACE_WITH_CREDENTIAL_ID" } }
    },
    {
      "id": "if1",
      "name": "Table Exists?",
      "type": "if",
      "typeVersion": 1,
      "position": [600, 300],
      "parameters": {
        "conditions": [
          {
            "value1": "json.table_exists",
            "operation": "equals",
            "value2": "true"
          }
        ],
        "combineOperation": "and"
      }
    },
    {
      "id": "createTable1",
      "name": "Create Table",
      "type": "postgres",
      "typeVersion": 1,
      "position": [850, 450],
      "parameters": {
        "operation": "executeSql",
        "query": "CREATE TABLE wf_logs (url_path VARCHAR(512), request_ts TIMESTAMP, parameter_name VARCHAR(255), parameter_value VARCHAR(255))"
      },
      "credentials": { "postgresApi": { "id": "REPLACE_WITH_CREDENTIAL_ID" } }
    },
    {
      "id": "genData1",
      "name": "Generate Random Record",
      "type": "code",
      "typeVersion": 1,
      "position": [1100, 300],
      "parameters": {
        "language": "javaScript",
        "mode": "runOnceForAllItems",
        "jsCode": "const paths = ['/api/users', '/api/orders', '/api/products', '/api/health', '/webhook/notify'];\nconst params = ['id', 'page', 'limit', 'sort', 'filter'];\nconst values = ['123', '1', '50', 'asc', 'active'];\n\nconst pick = arr => arr[Math.floor(Math.random() * arr.length)];\n\nreturn [{\n  json: {\n    url_path: pick(paths),\n    request_ts: new Date().toISOString(),\n    parameter_name: pick(params),\n    parameter_value: pick(values)\n  }\n}];"
      }
    },
    {
      "id": "insert1",
      "name": "Insert Record",
      "type": "postgres",
      "typeVersion": 1,
      "position": [1350, 300],
      "parameters": {
        "operation": "insert",
        "table": "wf_logs",
        "columns": [
          { "column": "url_path", "value": "={{$json.url_path}}" },
          { "column": "request_ts", "value": "={{$json.request_ts}}" },
          { "column": "parameter_name", "value": "={{$json.parameter_name}}" },
          { "column": "parameter_value", "value": "={{$json.parameter_value}}" }
        ]
      },
      "credentials": { "postgresApi": { "id": "REPLACE_WITH_CREDENTIAL_ID" } }
    },
    {
      "id": "fetchLatest1",
      "name": "Fetch Latest Row",
      "type": "postgres",
      "typeVersion": 1,
      "position": [1600, 300],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * FROM wf_logs ORDER BY request_ts DESC LIMIT 1"
      },
      "credentials": { "postgresApi": { "id": "REPLACE_WITH_CREDENTIAL_ID" } }
    }
  ],
  "connections": {
    "trigger1": {
      "main": [
        [{ "node": "checkTable1", "type": "main", "index": 0 }]
      ]
    },
    "checkTable1": {
      "main": [
        [{ "node": "if1", "type": "main", "index": 0 }]
      ]
    },
    "if1": {
      "main": [
        [{ "node": "genData1", "type": "main", "index": 0 }],
        [{ "node": "createTable1", "type": "main", "index": 0 }]
      ]
    },
    "createTable1": {
      "main": [
        [{ "node": "genData1", "type": "main", "index": 0 }]
      ]
    },
    "genData1": {
      "main": [
        [{ "node": "insert1", "type": "main", "index": 0 }]
      ]
    },
    "insert1": {
      "main": [
        [{ "node": "fetchLatest1", "type": "main", "index": 0 }]
      ]
    }
  },
  "settings": {},
  "staticData": {}
}
