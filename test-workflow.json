{
  "name": "Geocode Test Workflow",
  "nodes": [
    {
      "id": "webhook_1",
      "name": "Webhook",
      "type": "webhook",
      "typeVersion": 1,
      "parameters": {
        "httpMethod": "GET",
        "path": "/geocode-test",
        "authentication": "none",
        "responseMode": "lastNode"
      },
      "position": [200, 300]
    },
    {
      "id": "http_request_1",
      "name": "HTTP Request",
      "type": "httpRequest",
      "typeVersion": 1,
      "parameters": {
        "method": "GET",
        "url": "https://maps.googleapis.com/maps/api/geocode/json?address=google",
        "authentication": "none",
        "sendQuery": false,
        "sendHeaders": false,
        "sendBody": false,
        "options": {
          "neverError": true,
          "responseFormat": "json"
        }
      },
      "position": [500, 300]
    },
    {
      "id": "respond_1",
      "name": "Respond to Webhook",
      "type": "respondToWebhook",
      "typeVersion": 1,
      "parameters": {
        "respondWith": "firstIncomingItem",
        "responseCode": 200
      },
      "position": [800, 300]
    }
  ],
  "connections": {
    "webhook_1": {
      "main": [[{"node": "http_request_1", "type": "main", "index": 0}]]
    },
    "http_request_1": {
      "main": [[{"node": "respond_1", "type": "main", "index": 0}]]
    }
  },
  "settings": {}
}
