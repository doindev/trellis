      "type": "code",
      "typeVersion": 1,
      "position": [
        416,
        144
      ],
      "parameters": {
        "language": "javaScript",
        "mode": "runOnceForAllItems",
        "jsCode": "const randomNumber = Math.floor(Math.random() * 1000);\nconst isEven = randomNumber % 2 === 0;\n\nreturn [{\n  json: {\n    randomNumber,\n    isEven,\n    parity: isEven ? 'even' : 'odd',\n    generatedAt: new Date().toISOString()\n  }\n}];"
      }
    },
    {
      "id": "ifEven",
      "name": "Is Even?",
      "type": "if",
      "typeVersion": 1,
      "position": [
        608,
        144
      ],
      "parameters": {
        "conditions": [
          {
            "value1": "{{$json.isEven}}",
            "operation": "equals",
            "value2": "true"
          }
        ]
      }
    },
    {
      "id": "execWorkflow1",
      "name": "Execute Time API Logger",
      "type": "executeWorkflow",
      "typeVersion": 1,
      "position": [
