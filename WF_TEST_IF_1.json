{
  "name": "Test IF - Geocode Status Check",
  "description": "Webhook GET -> HTTP Request to Google Geocode API -> If status is REQUEST_DENIED return 400, otherwise return 403",
  "published": false,
  "currentVersion": 1,
  "nodes": [
    {
      "id": "webhook1",
      "name": "Webhook",
      "type": "webhook",
      "typeVersion": 1,
      "position": [100, 300],
      "parameters": {
        "httpMethod": "GET",
        "path": "geocode-check",
        "authentication": "none",
        "responseMode": "responseNode"
      }
    },
    {
      "id": "httpRequest1",
      "name": "HTTP Request",
      "type": "httpRequest",
      "typeVersion": 1,
      "position": [350, 300],
      "parameters": {
        "method": "GET",
        "url": "https://maps.googleapis.com/maps/api/geocode/json?address=google",
        "authentication": "none",
        "options": {
          "responseFormat": "json",
          "neverError": true
        }
      }
    },
    {
      "id": "if1",
      "name": "If REQUEST_DENIED",
      "type": "if",
      "typeVersion": 1,
      "position": [600, 300],
      "parameters": {
        "conditions": [
          {
            "value1": "json.status",
            "operation": "equals",
            "value2": "REQUEST_DENIED"
          }
        ],
        "combineOperation": "and"
      }
    },
    {
      "id": "respond400",
      "name": "Respond 400",
      "type": "respondToWebhook",
      "typeVersion": 1,
      "position": [900, 200],
      "parameters": {
        "respondWith": "allIncomingItems",
        "options": {
          "responseCode": 400
        }
      }
    },
    {
      "id": "respond403",
      "name": "Respond 403",
      "type": "respondToWebhook",
      "typeVersion": 1,
      "position": [900, 400],
      "parameters": {
        "respondWith": "allIncomingItems",
        "options": {
          "responseCode": 403
        }
      }
    }
  ],
  "connections": {
    "webhook1": {
      "main": [
        [
          { "node": "httpRequest1", "type": "main", "index": 0 }
        ]
      ]
    },
    "httpRequest1": {
      "main": [
        [
          { "node": "if1", "type": "main", "index": 0 }
        ]
      ]
    },
    "if1": {
      "main": [
        [
          { "node": "respond400", "type": "main", "index": 0 }
        ],
        [
          { "node": "respond403", "type": "main", "index": 0 }
        ]
      ]
    }
  },
  "settings": {},
  "staticData": {}
}
