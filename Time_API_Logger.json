      "parameters": {
        "inputSource": "passthrough"
      }
    },
    {
      "id": "httpGetTime",
      "name": "Get UTC Time",
      "type": "httpRequest",
      "typeVersion": 1,
      "position": [
        256,
        304
      ],
      "parameters": {
        "method": "GET",
        "url": "https://timeapi.io/api/v1/time/current/utc",
        "authentication": "none",
        "options": {
          "neverError": true,
          "timeout": 10000
        }
      }
    },
    {
      "id": "debugHttpResult",
      "name": "Log HTTP Result",
      "type": "debug",
      "typeVersion": 1,
      "position": [
        448,
        304
      ],
      "parameters": {
        "logLevel": "info",
        "logMessage": "Time API response received",
        "showFieldValues": true
      }
    },
    {
      "id": "checkTableExists",
      "name": "Check Table Exists",
      "type": "postgres",
      "typeVersion": 1,
      "position": [
        640,
        304
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT COUNT(*) AS table_count FROM information_schema.tables WHERE table_schema = 'public' AND table_name = 'workflow_results'"
      },
      "credentials": {
        "postgresApi": {
          "id": "l0ie_VpLV_c8EUTfEfOO0"
        }
      }
    },
    {
      "id": "ifTableExists",
      "name": "Table Exists?",
      "type": "if",
      "typeVersion": 1,
      "position": [
        832,
        304
      ],
      "parameters": {
        "conditions": [
          {
            "value1": "{{$json.table_count}}",
            "operation": "greaterThan",
            "value2": "0"
          }
        ]
      }
    },
    {
      "id": "createTable",
      "name": "Create Table",
      "type": "postgres",
      "typeVersion": 1,
      "position": [
        1040,
        384
      ],
      "parameters": {
        "operation": "executeSql",
        "query": "CREATE TABLE IF NOT EXISTS workflow_results (\n  id SERIAL PRIMARY KEY,\n  check_time TIMESTAMP,\n  result_data TEXT,\n  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP\n)"
      },
      "credentials": {
        "postgresApi": {
          "id": "l0ie_VpLV_c8EUTfEfOO0"
        }
      }
    },
    {
      "id": "debugTableCreated",
      "name": "Table Created",
      "type": "debug",
      "typeVersion": 1,
      "position": [
        1232,
        384
      ],
      "parameters": {
        "logLevel": "info",
        "logMessage": "Table 'workflow_results' created successfully",
        "showFieldValues": false
      }
    },
    {
      "id": "insertResult",
      "name": "Log Response to DB",
      "type": "postgres",
      "typeVersion": 1,
      "position": [
        1424,
        304
      ],
      "parameters": {
        "operation": "executeSql",
        "query": "INSERT INTO workflow_results (check_time, result_data) VALUES (CURRENT_TIMESTAMP, '={{ JSON.stringify($('Get UTC Time').item.json) }}')",
        "table": "INSERT INTO workflow_results (check_time, result_data) VALUES (CURRENT_TIMESTAMP, ?)",
        "columns": [
          {
            "column": "result_data",
            "value": "{{$node[\"Get UTC Time\"].json.utc_time}}"
          }
        ]
      },
      "credentials": {
        "postgresApi": {
          "id": "l0ie_VpLV_c8EUTfEfOO0"
        }
      }
    },
    {
      "id": "debugLogResult",
